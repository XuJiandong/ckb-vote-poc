{
  "name": "@ckb-vote/sdk",
  "version": "0.1.0",
  "description": "Off-chain SDK for CKB vote proposal lifecycle: create, vote, consume",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "ckb-vote": "./bin/ckb-vote.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@ckb-ccc/shell": "^1.0.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "onlyBuiltDependencies": [
    "esbuild"
  ]
}
