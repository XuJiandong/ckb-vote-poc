lor=#c8e6c4;align=left;verticalAlign=middle;spacingLeft=8;fontStyle=1;" vertex="1" parent="vc"><mxGeometry x="0" y="58" width="290" height="28" as="geometry"/></mxCell><mxCell id="vc-type-note" value="  (specified by proposal cell data)" style="text;html=1;strokeColor=#82b366;fillColor=#eaf7e8;align=left;verticalAlign=middle;fontStyle=2;" vertex="1" parent="vc"><mxGeometry x="0" y="86" width="290" height="24" as="geometry"/></mxCell><mxCell id="vc-args" value="Args: Type ID of Proposal Cell" style="text;html=1;strokeColor=#82b366;fillColor=#eaf7e8;align=left;verticalAlign=middle;spacingLeft=20;" vertex="1" parent="vc"><mxGeometry x="0" y="110" width="290" height="28" as="geometry"/></mxCell><mxCell id="vc-data-hdr" value="Cell Data" style="text;html=1;strokeColor=#82b366;fillColor=#c8e6c4;align=left;verticalAlign=middle;spacingLeft=8;fontStyle=1;" vertex="1" parent="vc"><mxGeometry x="0" y="138" width="290" height="26" as="geometry"/></mxCell><mxCell id="vc-d1" value="• vote result: yes / no" style="text;html=1;strokeColor=#82b366;fillColor=#eaf7e8;align=left;verticalAlign=middle;spacingLeft=16;" vertex="1" parent="vc"><mxGeometry x="0" y="164" width="290" height="26" as="geometry"/></mxCell><mxCell id="vc-deps" value="cell_deps: DAO deposit cell (same lock, used as vote weight)" style="text;html=1;strokeColor=#82b366;fillColor=#eaf7e8;align=left;verticalAlign=middle;spacingLeft=8;whiteSpace=wrap;" vertex="1" parent="vc"><mxGeometry x="0" y="190" width="290" height="40" as="geometry"/></mxCell><mxCell id="tc" value="Treasury Cell" style="swimlane;startSize=30;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=13;" vertex="1" parent="1"><mxGeometry x="780" y="60" width="310" height="200" as="geometry"/></mxCell><mxCell id="tc-lock-hdr" value="Lock Script: Treasury Lock Script" style="text;html=1;strokeColor=#d6b656;fillColor=#fffbe6;align=left;verticalAlign=middle;spacingLeft=8;fontStyle=1;" vertex="1" parent="tc"><mxGeometry x="0" y="30" width="310" height="28" as="geometry"/></mxCell><mxCell id="tc-r1" value="• Proposal type code_hash/hash_type must be valid" style="text;html=1;strokeColor=#d6b656;fillColor=#fffbe6;align=left;verticalAlign=middle;spacingLeft=16;whiteSpace=wrap;" vertex="1" parent="tc"><mxGeometry x="0" y="58" width="310" height="30" as="geometry"/></mxCell><mxCell id="tc-r2" value="• Proposal args must be valid (vk_hash)" style="text;html=1;strokeColor=#d6b656;fillColor=#fffbe6;align=left;verticalAlign=middle;spacingLeft=16;whiteSpace=wrap;" vertex="1" parent="tc"><mxGeometry x="0" y="88" width="310" height="30" as="geometry"/></mxCell><mxCell id="tc-unlock" value="Unlocked when proposal type script is active in same TX" style="text;html=1;strokeColor=#d6b656;fillColor=#ffe6a0;align=left;verticalAlign=middle;spacingLeft=8;fontStyle=2;whiteSpace=wrap;" vertex="1" parent="tc"><mxGeometry x="0" y="118" width="310" height="30" as="geometry"/></mxCell><mxCell id="tc-data" value="Cell Data: CKB Assets" style="text;html=1;strokeColor=#d6b656;fillColor=#fff3b0;align=left;verticalAlign=middle;spacingLeft=8;fontStyle=1;" vertex="1" parent="tc"><mxGeometry x="0" y="148" width="310" height="28" as="geometry"/></mxCell><mxCell id="e1" value="specifies vote_cell_code_hash / hash_type" style="edgeStyle=orthogonalEdgeStyle;html=1;curved=1;exitX=1;exitY=0.38;exitDx=0;exitDy=0;entryX=0;entryY=0.38;entryDx=0;entryDy=0;strokeColor=#6c8ebf;fontColor=#6c8ebf;fontSize=10;" edge="1" source="pc" target="vc" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e2" value="args: Type ID of Proposal Cell" style="edgeStyle=orthogonalEdgeStyle;html=1;curved=1;exitX=0;exitY=0.58;exitDx=0;exitDy=0;entryX=1;entryY=0.58;entryDx=0;entryDy=0;strokeColor=#82b366;fontColor=#82b366;fontSize=10;" edge="1" source="vc" target="pc" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e3" value="validates proposal type script" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.1;exitY=0;exitDx=0;exitDy=0;entryX=1;entryY=0.1;entryDx=0;entryDy=0;strokeColor=#d6b656;fontColor=#d6b656;fontSize=10;" edge="1" source="tc" target="pc" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="811" y="40"/><mxPoint x="370" y="40"/></Array></mxGeometry></mxCell><mxCell id="zkvm-label" value="zkVM Verifying Process" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="430" width="320" height="30" as="geometry"/></mxCell><mxCell id="offchain" value="Off-chain: SP1 Guest Program" style="swimlane;startSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="470" width="460" height="310" as="geometry"/></mxCell><mxCell id="oc-in" value="Inputs:&#xa;• Block data: begin block to begin+duration consecutive blocks&#xa;• DAO deposits map (for vote weight)&#xa;• Proposal type script + cell data" style="text;html=1;strokeColor=#b85450;fillColor=#fce4e4;align=left;verticalAlign=top;spacingLeft=8;whiteSpace=wrap;" vertex="1" parent="offchain"><mxGeometry x="0" y="30" width="460" height="80" as="geometry"/></mxCell><mxCell id="oc-proc" value="Processing:&#xa;1. Verify parent_hash chain between adjacent blocks&#xa;2. Verify transactions_root in each block header&#xa;3. Parse blocks → iterate cells → find vote cells&#xa;4. For each vote cell: check DAO deposit in cell_deps,&#xa;   count vote in Map (later votes overwrite earlier)&#xa;5. Passing rule: count(YES) &gt; count(NO) &amp;&amp;&#xa;   count(YES)+count(NO) &gt; min_requirement" style="text;html=1;strokeColor=#b85450;fillColor=#fce4e4;align=left;verticalAlign=top;spacingLeft=8;whiteSpace=wrap;" vertex="1" parent="offchain"><mxGeometry x="0" y="110" width="460" height="130" as="geometry"/></mxCell><mxCell id="oc-out" value="Public Values committed in proof:&#xa;start_hash | end_hash | proposal_type_script + cell_data | passed" style="text;html=1;strokeColor=#b85450;fillColor=#f4a0a0;align=left;verticalAlign=middle;spacingLeft=8;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="offchain"><mxGeometry x="0" y="240" width="460" height="56" as="geometry"/></mxCell><mxCell id="onchain" value="On-chain: Proposal Type Script Verification" style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="560" y="470" width="450" height="310" as="geometry"/></mxCell><mxCell id="on-s1" value="1. Read SP1_vk_hash from type script args" style="text;html=1;strokeColor=#9673a6;fillColor=#f3e8f8;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="onchain"><mxGeometry x="0" y="30" width="450" height="30" as="geometry"/></mxCell><mxCell id="on-s2" value="2. Read SP1 proof from witness" style="text;html=1;strokeColor=#9673a6;fillColor=#f3e8f8;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="onchain"><mxGeometry x="0" y="60" width="450" height="30" as="geometry"/></mxCell><mxCell id="on-s3" value="3. Parse proof → extract public values" style="text;html=1;strokeColor=#9673a6;fillColor=#f3e8f8;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="onchain"><mxGeometry x="0" y="90" width="450" height="30" as="geometry"/></mxCell><mxCell id="on-s4" value="4. Call SP1 verifier → verify proof validity" style="text;html=1;strokeColor=#9673a6;fillColor=#f3e8f8;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="onchain"><mxGeometry x="0" y="120" width="450" height="30" as="geometry"/></mxCell><mxCell id="on-s5" value="5. Validate public values vs on-chain data:&#xa;   • start_hash == header_dep[0]&#xa;   • end_hash == header_dep[1]&#xa;   • proposal type script + cell data match&#xa;   • passed == true" style="text;html=1;strokeColor=#9673a6;fillColor=#f3e8f8;align=left;verticalAlign=top;spacingLeft=8;whiteSpace=wrap;" vertex="1" parent="onchain"><mxGeometry x="0" y="150" width="450" height="100" as="geometry"/></mxCell><mxCell id="on-result" value="✓ Proof valid → Proposal Cell destroyed + Treasury unlocked" style="text;html=1;strokeColor=#9673a6;fillColor=#c9a6e0;align=left;verticalAlign=middle;spacingLeft=8;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="onchain"><mxGeometry x="0" y="250" width="450" height="44" as="geometry"/></mxCell><mxCell id="receiver" value="&lt;b&gt;Receiver Output Cell&lt;/b&gt;&lt;br&gt;Lock: receiver (from proposal cell data)&lt;br&gt;Capacity: amount (from proposal cell data)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="780" y="810" width="310" height="80" as="geometry"/></mxCell><mxCell id="e-proof" value="SP1 Proof (stored in witness)" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.85;exitDx=0;exitDy=0;entryX=0;entryY=0.85;entryDx=0;entryDy=0;strokeColor=#b85450;fontColor=#b85450;fontSize=11;fontStyle=1;strokeWidth=2;" edge="1" source="offchain" target="onchain" parent="1"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="e-destroy" value="destroys (proof valid)" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.15;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#9673a6;fontColor=#9673a6;fontSize=10;dashed=1;strokeWidth=1.5;" edge="1" source="onchain" target="pc" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="628" y="450"/><mxPoint x="205" y="450"/></Array></mxGeometry></mxCell><mxCell id="e-unlock" value="unlocks treasury" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.9;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#9673a6;fontColor=#9673a6;fontSize=10;dashed=1;strokeWidth=1.5;" edge="1" source="onchain" target="tc" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="965" y="440"/></Array></mxGeometry></mxCell><mxCell id="e-funds" value="releases funds to" style="edgeStyle=orthogonalEdgeStyle