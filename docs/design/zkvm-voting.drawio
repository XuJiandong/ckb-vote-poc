1;strokeColor=#82b366;fillColor=#c8e6c4;align=left;verticalAlign=middle;spacingLeft=8;fontStyle=1;" vertex="1" parent="vc"><mxGeometry x="0" y="58" width="290" height="28" as="geometry" /></mxCell><mxCell id="vc-type-note" value="  (specified by proposal cell data)" style="text;html=1;strokeColor=#82b366;fillColor=#eaf7e8;align=left;verticalAlign=middle;fontStyle=2;" vertex="1" parent="vc"><mxGeometry x="0" y="86" width="290" height="24" as="geometry" /></mxCell><mxCell id="vc-args" value="Args: blake160(proposal type script)[20B]" style="text;html=1;strokeColor=#82b366;fillColor=#eaf7e8;align=left;verticalAlign=middle;spacingLeft=20;" vertex="1" parent="vc"><mxGeometry x="0" y="110" width="290" height="28" as="geometry" /></mxCell><mxCell id="vc-data-hdr" value="Cell Data" style="text;html=1;strokeColor=#82b366;fillColor=#c8e6c4;align=left;verticalAlign=middle;spacingLeft=8;fontStyle=1;" vertex="1" parent="vc"><mxGeometry x="0" y="138" width="290" height="26" as="geometry" /></mxCell><mxCell id="vc-d1" value="• vote: 0x00=NO / 0x01=YES" style="text;html=1;strokeColor=#82b366;fillColor=#eaf7e8;align=left;verticalAlign=middle;spacingLeft=16;" vertex="1" parent="vc"><mxGeometry x="0" y="164" width="290" height="26" as="geometry" /></mxCell><mxCell id="vc-d2" value="• amount: total CKB in voter's DAO deposits" style="text;html=1;strokeColor=#82b366;fillColor=#eaf7e8;align=left;verticalAlign=middle;spacingLeft=16;" vertex="1" parent="vc"><mxGeometry x="0" y="190" width="290" height="26" as="geometry" /></mxCell><mxCell id="vc-d3" value="• dao_index: indices into cell_deps (DAO cells)" style="text;html=1;strokeColor=#82b366;fillColor=#eaf7e8;align=left;verticalAlign=middle;spacingLeft=16;" vertex="1" parent="vc"><mxGeometry x="0" y="216" width="290" height="26" as="geometry" /></mxCell><mxCell id="vc-deps" value="cell_deps: Proposal Cell + DAO deposit cell (same lock, vote weight)" style="text;html=1;strokeColor=#82b366;fillColor=#eaf7e8;align=left;verticalAlign=middle;spacingLeft=8;whiteSpace=wrap;" vertex="1" parent="vc"><mxGeometry x="0" y="242" width="290" height="40" as="geometry" /></mxCell><mxCell id="e1" value="specifies vote_cell_code_hash / hash_type" style="edgeStyle=orthogonalEdgeStyle;html=1;curved=1;exitX=1;exitY=0.38;exitDx=0;exitDy=0;entryX=0;entryY=0.38;entryDx=0;entryDy=0;strokeColor=#6c8ebf;fontColor=#6c8ebf;fontSize=10;" edge="1" source="pc" target="vc" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e2" value="args: blake160(proposal type script)" style="edgeStyle=orthogonalEdgeStyle;html=1;curved=1;exitX=0;exitY=0.58;exitDx=0;exitDy=0;entryX=1;entryY=0.58;entryDx=0;entryDy=0;strokeColor=#82b366;fontColor=#82b366;fontSize=10;" edge="1" source="vc" target="pc" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="zkvm-label" value="zkVM Verifying Process" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="40" y="430" width="320" height="30" as="geometry" /></mxCell><mxCell id="offchain" value="Off-chain: SP1 Guest Program" style="swimlane;startSize=30;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="470" width="460" height="310" as="geometry" /></mxCell><mxCell id="oc-in" value="Inputs:
• Block data: Block 0 to Block N (duration+1 consecutive blocks)
• DAO deposits map (for vote weight)
• Proposal type script + cell data" style="text;html=1;strokeColor=#b85450;fillColor=#fce4e4;align=left;verticalAlign=top;spacingLeft=8;whiteSpace=wrap;" vertex="1" parent="offchain"><mxGeometry x="0" y="30" width="460" height="80" as="geometry" /></mxCell><mxCell id="oc-proc" value="Processing:
1. Verify parent_hash chain between adjacent blocks
2. Verify transactions_root in each block header
3. Parse blocks → iterate cells → find vote cells
4. For each vote cell: check DAO deposit in cell_deps,
   count vote in Map (key=lock_hash; later votes overwrite earlier)
   DAO deposit out_points tracked in Set (no double-counting)
5. Passing rule: sum(YES) &gt; sum(NO) &amp;&amp; sum(YES) + sum(NO) &gt; min_requirement" style="text;html=1;strokeColor=#b85450;fillColor=#fce4e4;align=left;verticalAlign=top;spacingLeft=8;whiteSpace=wrap;" vertex="1" parent="offchain"><mxGeometry x="0" y="110" width="460" height="130" as="geometry" /></mxCell><mxCell id="oc-out" value="Public Values committed in proof:
duration | vote_cell_code_hash/hash_type | receiver | amount | minimal_requirement
| start_block_hash | end_block_hash | passed | proposal_script" style="text;html=1;strokeColor=#b85450;fillColor=#f4a0a0;align=left;verticalAlign=middle;spacingLeft=8;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="offchain"><mxGeometry x="0" y="240" width="460" height="56" as="geometry" /></mxCell><mxCell id="onchain" value="On-chain: Proposal Type Script Verification" style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="560" y="470" width="450" height="310" as="geometry" /></mxCell><mxCell id="on-s1" value="1. Read SP1_vk_hash from type script args" style="text;html=1;strokeColor=#9673a6;fillColor=#f3e8f8;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="onchain"><mxGeometry x="0" y="30" width="450" height="30" as="geometry" /></mxCell><mxCell id="on-s2" value="2. Read SP1 proof from witness (WitnessArgs.output_type)" style="text;html=1;strokeColor=#9673a6;fillColor=#f3e8f8;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="onchain"><mxGeometry x="0" y="60" width="450" height="30" as="geometry" /></mxCell><mxCell id="on-s3" value="3. Parse proof → extract public values" style="text;html=1;strokeColor=#9673a6;fillColor=#f3e8f8;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="onchain"><mxGeometry x="0" y="90" width="450" height="30" as="geometry" /></mxCell><mxCell id="on-s4" value="4. Call SP1 PLONK verifier → verify proof validity" style="text;html=1;strokeColor=#9673a6;fillColor=#f3e8f8;align=left;verticalAlign=middle;spacingLeft=8;" vertex="1" parent="onchain"><mxGeometry x="0" y="120" width="450" height="30" as="geometry" /></mxCell><mxCell id="on-s5" value="5. Validate public values vs on-chain data:
   • start_hash == header_dep[0]
   • end_hash == header_dep[1]
   • duration, vote_cell_code_hash/hash_type, receiver, amount,
     minimal_requirement, proposal_script match cell data
   • passed == 1" style="text;html=1;strokeColor=#9673a6;fillColor=#f3e8f8;align=left;verticalAlign=top;spacingLeft=8;whiteSpace=wrap;" vertex="1" parent="onchain"><mxGeometry x="0" y="150" width="450" height="110" as="geometry" /></mxCell><mxCell id="on-result" value="✓ Proof valid → Proposal Cell destroyed + receiver output created" style="text;html=1;strokeColor=#9673a6;fillColor=#c9a6e0;align=left;verticalAlign=middle;spacingLeft=8;whiteSpace=wrap;fontStyle=1;" vertex="1" parent="onchain"><mxGeometry x="0" y="260" width="450" height="44" as="geometry" /></mxCell><mxCell id="receiver" value="&lt;b&gt;Receiver Output Cell&lt;/b&gt;&lt;br&gt;Lock: receiver (from proposal cell data)&lt;br&gt;Capacity: amount (from proposal cell data)&lt;br&gt;&lt;i&gt;Funded from proposal cell capacity&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="780" y="60" width="310" height="100" as="geometry" /></mxCell><mxCell id="e-proof" value="SP1 Proof (stored in witness)" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.85;exitDx=0;exitDy=0;entryX=0;entryY=0.85;entryDx=0;entryDy=0;strokeColor=#b85450;fontColor=#b85450;fontSize=11;fontStyle=1;strokeWidth=2;" edge="1" source="offchain" target="onchain" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e-destroy" value="destroys (proof valid)" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=0.15;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#9673a6;fontColor=#9673a6;fontSize=10;dashed=1;strokeWidth=1.5;" edge="1" source="onchain" target="pc" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="628" y="450" /><mxPoint x="205" y="450" /></Array></mxGeometry></mxCell><mxCell id="pc-cap" value="• capacity: escrows CKB (≥ amount) at creation" style="text;html=1;strokeColor=#6c8ebf;fillColor=#eff7ff;align=left;verticalAlign=middle;spacingLeft=16;" vertex="1" parent="pc"><mxGeometry x="0" y="314" width="330" height="26" as="geometry" /></mxCell><mxCell id="e-payout" value="creates receiver output" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.75;entryDx=0;entryDy=0;strokeColor=#9673a6;fontColor=#9673a6;fontSize=10;dashed=1;strokeWidth=1.5;" edge="1" source="onchain" target="receiver" parent="1"><mxGeometry relative="1" as="geometry" /></mxCell><mxCell id="e-escrow" value="releases escrowed CKB" style="edgeStyle=orthogonalEdgeStyle;html=1;exitX=1;exitY=0.85;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;strokeColor=#6c8ebf;fontColor=#6c8ebf;fontSize=10;strokeWidth=2;" edge="1" source="pc" target="receiver" parent="1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="370" y="371" /><mxPoint x="935" y="371" /></Array></mxGeometry></mxCell></root></mxGraphModel>